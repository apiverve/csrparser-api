            "email": "hello@apiverve.com",
            "homepage": "https://apiverve.com"
        }
    ],
    "keywords": [
        "api",
        "apiverve",
        "csrparser",
        "csr parser",
        "certificate signing request",
        "ssl certificate",
        "x509",
        "pem format"
    ],
    "homepage": "https://apiverve.com/marketplace/csrparser?utm_source=php&utm_medium=homepage",
    "support": {
        "email": "hello@apiverve.com",
        "docs": "https://docs.apiverve.com/ref/csrparser",
        "source": "https://github.com/apiverve/csrparser-API/tree/main/php"
    },
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "APIVerve\\Csrparser\\": "php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "APIVerve\\Csrparser\\Tests\\": "php/tests/"
        }
    },
    "minimum-stability": "stable",
